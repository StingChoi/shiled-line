@echo off
chcp 65001 >nul
cd /d D:\shiled-line

echo ============================================================
echo   쉴드광택 - 홈페이지 + 구글 블로거 한방 발행
echo ============================================================
echo.
echo  [1/3] 홈페이지에 새 글을 올립니다 (GitHub Push)...
echo.

git add -A
git commit -m "새 작업 글 추가 (자동발행)"
git push

echo.
echo  [2/3] 홈페이지에 사진이 반영되길 기다립니다 (90초)...
echo        (블로거가 홈페이지 사진을 빌려오기 때문에 잠깐 기다립니다)
echo.

timeout /t 90 /nobreak

echo.
echo  [3/3] 가장 최근 글을 구글 블로거에 발행합니다...
echo.

py post_html.py

echo.
echo ============================================================
echo   끝났습니다!
echo   - 홈페이지 : 1~2분 내 www.shiled-line.com/blog 반영
echo   - 블로거   : 위에 뜬 주소 확인 (지금은 '초안'으로 올라감)
echo ============================================================
echo.
pause
